{
  "name": "@tickpad/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tickpad is a plugin-first Markdown editor.",
  "author": "Tickpad contributors",
  "productName": "Tickpad",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --host 127.0.0.1",
    "build": "electron-vite build",
    "package:mac": "electron-vite build && electron-builder --mac dir",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "app.tickpad.desktop",
    "productName": "Tickpad",
    "asar": true,
    "files": [
      "out/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": null,
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      }
    }
  },
  "dependencies": {
    "@codemirror/language": "6.12.4",
    "@codemirror/language-data": "6.5.2",
    "@tickpad/config": "workspace:*",
    "@tickpad/editor-core": "workspace:*",
    "@tickpad/export": "workspace:*",
    "@tickpad/markdown-engine": "workspace:*",
    "@tickpad/plugin-host": "workspace:*",
    "@tickpad/plugin-ai-writer": "workspace:*",
    "@tickpad/plugin-mermaid": "workspace:*",
    "@tickpad/plugin-vercel-templates": "workspace:*",
    "@tickpad/plugin-wechat-export": "workspace:*",
    "@tickpad/plugin-word-count": "workspace:*",
    "@tickpad/shared": "workspace:*",
    "@milkdown/crepe": "^7.21.1",
    "lucide-react": "^0.561.0",
    "mermaid": "^11.16.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-vite": "^4.0.0"
  }
}
